# Planningtool v0.9 — Omgevingsvariabelen
# Kopieer dit bestand naar .env en vul de waarden in.
# .env mag NOOIT in git terechtkomen.

# ── Database ────────────────────────────────────────────
POSTGRES_DB=planningtool
POSTGRES_USER=planningtool
POSTGRES_PASSWORD=verander-dit-naar-een-sterk-wachtwoord

DATABASE_URL=postgresql://planningtool:verander-dit-naar-een-sterk-wachtwoord@db:5432/planningtool

# ── Applicatie ──────────────────────────────────────────
# Genereer een unieke sleutel per omgeving:
#   python -c "import secrets; print(secrets.token_hex(32))"
GEHEIME_SLEUTEL=dev-geheime-sleutel-ALLEEN-voor-lokale-test-niet-in-productie

OMGEVING=development
# Zet op 'production' bij deployment op NAS

APP_VERSIE=0.9.0

# ── Auth ────────────────────────────────────────────────
TOEGANGS_TOKEN_VERLOPEN_MINUTEN=30
TOTP_ISSUER=Planningtool

# ── Seed ────────────────────────────────────────────────
# Wachtwoord voor de seed-beheerder (alleen development).
# Als niet ingesteld wordt een willekeurig wachtwoord gegenereerd en gelogd.
SEED_ADMIN_WACHTWOORD=verander_dit_direct

# ── CORS / Hosts ────────────────────────────────────────
ALLOWED_HOSTS=localhost,127.0.0.1
# In productie: je Cloudflare Tunnel domein toevoegen
